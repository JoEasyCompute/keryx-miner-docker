MINING_ADDRESS=keryx:YOUR_ADDRESS

# Upstream release binary to install.
KERYX_MINER_VERSION=v0.3.5-OPoI
KERYX_MINER_SHA256=c9770a52a7c41c4e17b20cb643b5e5c13e40b8bda9293a7d04e95c866c644b93

# Runtime mode. Use default, light, high, or very-high.
KERYX_INFERENCE_TIER=default

# Set true for PoW only.
KERYX_NO_OPOI=false

# Optional raw miner flags, for example: --devfund-percent 2.0
KERYX_EXTRA_ARGS=

# Optional GPU tuning before the miner starts.
KERYX_GPU_TUNING=false
KERYX_GPU_PRESET=none
KERYX_GPU_DEVICES=

# Optional CSV GPU presets. URL fetch enables presets automatically.
KERYX_GPU_PRESETS_ENABLE=false
KERYX_GPU_PRESETS_URL=
KERYX_GPU_PRESETS_FILE=/etc/keryx/gpu-presets.csv
KERYX_GPU_PRESETS_SHA256=
KERYX_GPU_PRESETS_DRY_RUN=false
KERYX_GPU_PRESETS_TIMEOUT=10
KERYX_GPU_PRESETS_ALGORITHM=keryx

# Power limit in watts, or use a percentage of each GPU's default power limit.
KERYX_GPU_POWER_LIMIT=
KERYX_GPU_POWER_LIMIT_PERCENT=

# Absolute clock locks in MHz. Use one value, or min:max.
KERYX_GPU_LOCK_CORE_CLOCK=
KERYX_GPU_LOCK_MEMORY_CLOCK=

# Clock offsets usually require host X/NV-CONTROL Coolbits and nvidia-settings.
KERYX_GPU_CORE_CLOCK_OFFSET=
KERYX_GPU_MEMORY_CLOCK_OFFSET=
KERYX_GPU_USE_NVIDIA_SETTINGS=false

KERYX_GPU_RESET_CLOCKS_FIRST=false
KERYX_GPU_TUNING_STRICT=false

# Use a comma-separated list such as 0,1 to select GPUs, or all.
NVIDIA_VISIBLE_DEVICES=all
